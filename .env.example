### MongoDB
MONGODB_URI=mongodb://localhost:27017/chileconnected
MONGODB_DB=chileconnected

### Groq
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile

### RAG / Vector
# Prefer Atlas Vector Search; if false, uses cosine fallback in app.
USE_ATLAS_VECTOR=false
# Atlas vector index name (create it in Atlas UI)
ATLAS_VECTOR_INDEX=beneficios_embedding_v1

### Scraping
SCRAPE_USER_AGENT=ChileConnectedBot/1.0 (+contacto@tu-dominio.cl)
SCRAPE_HEADLESS=true
SCRAPE_CONCURRENCY=2

### Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

