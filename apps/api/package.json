    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "groq-sdk": "^1.1.1",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.1",
    "p-limit": "^3.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "robots-parser": "^3.0.1",
    "zod": "^4.3.6"
  },
